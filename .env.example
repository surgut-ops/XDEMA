# ═══════════════════════════════════════════
#  XDEMA — Environment Variables
#  Copy this file to backend/.env and fill in
# ═══════════════════════════════════════════

# ── DATABASE ──────────────────────────────
DATABASE_URL="postgresql://xdema:xdema_secret@localhost:5432/xdema_db"

# ── SECURITY ──────────────────────────────
JWT_SECRET="HuPwlu5eFN/RpyiICrJkib5mNLVcENoAZkqkNLXv5HM="
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# ── ADMIN SEED ────────────────────────────
ADMIN_EMAIL="admin@xdema.ru"
ADMIN_PASSWORD="Xdema086"

# ── STRIPE ────────────────────────────────
# Get keys from: stripe.com → Dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLIC_KEY="pk_test_..."
# Get from: stripe.com → Webhooks → Add endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── EMAIL (Gmail App Password) ────────────
# Google Account → Security → 2-Step → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="XDEMA <your@gmail.com>"

# ── TELEGRAM BOT ──────────────────────────
# 1. Open @BotFather in Telegram → /newbot
# 2. Get Chat ID: add @userinfobot to your group
TELEGRAM_BOT_TOKEN="123456789:ABC-DEFGhijklmNOP..."
TELEGRAM_CHAT_ID="-100123456789"

# ── FILE STORAGE (Yandex Object Storage) ──
# console.yandex.cloud → Object Storage → Create bucket
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_BUCKET="xdema-media"
S3_REGION="ru-central1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_PUBLIC_URL="https://storage.yandexcloud.net/xdema-media"

# ── APP URLS ──────────────────────────────
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ── RUNTIME ───────────────────────────────
PORT=3001
NODE_ENV="development"

# ── NEXT.JS PUBLIC (copy to frontend/.env.local) ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_STRIPE_PK="pk_test_..."
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
